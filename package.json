{
  "name": "@mitchallen/connection-grid",
  "version": "0.1.36",
  "description": "map connections between cells in a 2D grid",
  "main": "src/index.js",
  "browser": "dist/connection-grid.min.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "node build.js",
    "lint": "eslint src/",
    "test": "node build.js && node --test $(find test -name '*-test.js' | sort)",
    "coverage": "node build.js && node --test --experimental-test-coverage --test-coverage-exclude='test/**' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info $(find test -name '*-test.js' | sort)",
    "watch": "node build.js --watch",
    "test-circle": "node --test $(find test/circle   -name '*-test.js')",
    "test-create": "node --test $(find test/create   -name '*-test.js')",
    "test-hexagon": "node --test $(find test/hexagon  -name '*-test.js')",
    "test-square": "node --test $(find test/square   -name '*-test.js')",
    "test-triangle": "node --test $(find test/triangle -name '*-test.js')",
    "test-debug": "node --test $(find test -name '*-test.js' | sort)",
    "pubinit": "node build.js && npm publish",
    "publish-pkg": "node build.js && npm version patch && git push --follow-tags && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mitchallen/connection-grid.git"
  },
  "author": "Mitch Allen <npm@mitchallen.com> (http://mitchallen.com)",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "globals": "^16.0.0"
  },
  "dependencies": {
    "@mitchallen/connection-grid-square": "^0.1.17",
    "@mitchallen/grid": "^0.1.25",
    "@mitchallen/grid-square": "^0.1.9",
    "@mitchallen/shuffle": "^0.1.7"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
